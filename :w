const fs = require('fs');
const [n, k] = fs.readFileSync(0, 'utf8').split(' ');

const digs = n.split('').map(Number);
for (let i = digs.length - 1; i >= 0; i--) {
    const digit = digs[i];
    let j = i - 1;
    for (; j >= 0; j--) if (digs[j] < digit) break;
    [digs[i], digs[j]] = [digs[j], digs[i]];
}

console.log(digs.join(''))
